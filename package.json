{
  "name": "portfolio-website",
  "version": "1.0.0",
  "description": "Personal Portfolio Website - Sanjana RD",
  "main": "server/server.js",
  "scripts": {
    "client": "cd client && npm start",
    "server": "nodemon server/server.js",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
